# ============================================
# KitchenGPT Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.

# Google API key — used for Places API and YouTube Data API.
# Must have "Places API (New)" enabled.
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API key — used for vision analysis and recipe generation.
# (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model for vision and recipe generation
MODEL_NAME=gpt-5-mini-2025-08-07

# Supabase project URL and anon/service key
# (https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Optional overrides (defaults are fine for development)
# DEBUG=true
# ALLOWED_ORIGINS=["http://localhost:3000"]
# RECIPE_RESULTS_LIMIT=5
# PLACES_SEARCH_RADIUS=5000
